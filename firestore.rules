rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdministrator() {
      return signedIn() &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'Administrador';
    }

    match /usuarios/{userId} {
      allow get: if signedIn() && (request.auth.uid == userId || isAdministrator());
      allow list, create, delete: if isAdministrator();
      allow update: if isAdministrator() ||
        (request.auth.uid == userId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ultimoIngreso']));
    }
  }
}
